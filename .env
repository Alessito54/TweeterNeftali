PORT=3000
CUSTOM_NOTE="Local dev: using SQLite. Set USE_SQLITE=false to use Postgres"
USE_SQLITE=true

# Fill these values locally before running against production services.
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
AIVEN_CA_B64=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

JWT_SECRET=replace-with-a-strong-secret
